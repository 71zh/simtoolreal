# Copy this file to env.local in the same folder and fill in values.
# env.local is gitignored.
#
# SSH: recommend adding your public key to AutoDL once, then leave password empty.
# Password mode needs: sudo apt install sshpass   (Linux)

AUTO_DL_HOST=connect.cqa1.seetacloud.com
AUTO_DL_PORT=21268
AUTO_DL_USER=root

# Where the repo lives on the GPU instance (adjust if you cloned elsewhere)
AUTO_DL_REPO_DIR=/root/autodl-tmp/simtoolreal

# Leave empty if you use SSH key auth (default ~/.ssh/id_ed25519)
# AUTO_DL_PASSWORD=

# Optional explicit key path
# SSH_IDENTITY_FILE=/home/yourname/.ssh/id_ed25519

# Optional: where fetch-runs copies remote runs/. Default ~/Downloads/autodl_simtoolreal_runs
# LOCAL_RUNS_DIR=/home/you/Downloads/autodl_simtoolreal_runs
